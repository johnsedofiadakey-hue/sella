DATABASE_URL=postgres://shoplocal:shoplocal@localhost:5433/shoplocal

# Root storefront domain used to derive tenant subdomains in production
# (e.g. amasfashion.shoplocal.app). Left unset locally — middleware falls
# back to ?store=slug on localhost.
ROOT_DOMAIN=shoplocal.app

# Left unset until the StormGlide business account exists (Part 5 Phase 0).
# Checkout falls back to pay-on-delivery only while these are unset —
# see lib/paystack.ts.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
