DATABASE_URL=postgres://sella:sella@localhost:5433/sella

# Root storefront domain used to derive tenant subdomains in production
# (e.g. amasfashion.sella.app). Left unset locally — middleware falls
# back to ?store=slug on localhost.
ROOT_DOMAIN=sella.app

# Left unset until the StormGlide business account exists (Part 5 Phase 0).
# Checkout falls back to pay-on-delivery only while these are unset —
# see lib/paystack.ts.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Left unset until a Sentry project exists (Part 5 Phase 0/Month 4). Errors
# log to the console instead while these are unset — see lib/monitoring.ts.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Nightly backup target (Part 3 §2's Cloudflare R2). Left unset locally —
# scripts/backup.ts writes the dump under ./backups instead. See that file
# for the exact bucket layout.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BACKUP_BUCKET=
